---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("writing");

// newest first
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tags = [
  "All",
  ...new Set(posts.flatMap(post => post.data.tags ?? []))
];
---

<BaseLayout title="Writing">

<section class="writing">

  <div class="main">

    <p class="intro">
      All my writing here is reflective, non-academic,
      and written without LLM editing. Expect some errors here and there.
    </p>

    <nav class="tags">
      {tags.map((tag, i) => (
        <a
          href="#"
          class={`tag-btn${i === 0 ? " active" : ""}`}
          data-tag={tag}
        >{tag}</a>
      ))}
    </nav>

    <div class="articles">

      {posts.map(post => {
        const slug = post.id.replace(/\.md$/, "");
        const postTags = post.data.tags ?? [];

        return (
          <a
            href={`/writing/${slug}`}
            class="card"
            data-tags={JSON.stringify(postTags)}
          >
            <h2>{post.data.title}</h2>

            <p>{post.data.description}</p>

            <small>
              {post.data.date.toLocaleDateString()}
            </small>
          </a>
        );
      })}

    </div>

  </div>

  <aside>

    <h3>Possible Articles...</h3>

    <ul>
      <li>Conscious Chatbots Might Have an Upside</li>
      <li>Robots: Moral Patients?</li>
      <li><i>Imago Dei</i> and Human-made Automata</li>
      <li>Thoughtful Christianity</li>
      <li>Robots in Warfare</li>
      <li>What is Emergence?</li>
      <li>The Really Hard Problem of Consciousness</li>
    </ul>

  </aside>

</section>

<script>
  const tagBtns = document.querySelectorAll<HTMLAnchorElement>(".tag-btn");
  const cards = document.querySelectorAll<HTMLAnchorElement>(".card");

  tagBtns.forEach(btn => {
    btn.addEventListener("click", e => {
      e.preventDefault();
      tagBtns.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");

      const selected = btn.dataset.tag ?? "All";

      cards.forEach(card => {
        const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
        const show = selected === "All" || tags.includes(selected);
        card.style.display = show ? "" : "none";
      });
    });
  });
</script>

</BaseLayout>

<style>

section.writing{
    display:grid;
    grid-template-columns:2fr 240px;
    gap:60px;
}

.intro{
    line-height:1.6;
    margin-bottom:2rem;
}

.tags{
    display:flex;
    gap:1rem;
    flex-wrap:wrap;
    margin-bottom:3rem;
}

.tags a{
    color:#666;
    text-decoration:none;
}

.tags a.active{
    color:inherit;
    font-weight:600;
    text-decoration:underline;
}

.articles{
    display:flex;
    flex-direction:column;
    gap:2rem;
}

.card{
    display:block;
    color:inherit;
    text-decoration:none;
    border-bottom:1px solid #ddd;
    padding-bottom:2rem;
}

.card h2{
    margin-bottom:.5rem;
}

.card p{
    margin-bottom:.75rem;
}

aside{
    font-size:.9rem;
    color:#555;
    line-height:1.6;
}

</style>