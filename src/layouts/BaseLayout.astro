---
import Header
from "../components/Header.astro";

import "../styles/global.css";

const {
title
} = Astro.props;

/*
get current url
*/

const currentPath =
Astro.url.pathname;
---

<html>

<head>

<title>

{title}

</title>

</head>

<body>

<div class="site-shell">

<Header currentPath={currentPath}/>

<main>

<slot />

</main>

</div>

</body>

</html>

<style>


body {

background: var(--back);

margin: 0;

min-height: 100vh;

}

.site-shell {
    
width: min(1000px, 90vw);

margin:

0rem
auto
0rem;

background: var(--bg-text);

}

main {

padding:

4rem
6rem
6rem;

box-sizing: border-box;

}

header {

margin: 0;

}

</style>